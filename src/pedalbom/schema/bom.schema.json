{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pedalbom.local/schema/bom.schema.json",
  "title": "PedalBOM Extracted BOM",
  "type": "object",
  "required": ["schema_version", "project", "items"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "project": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "vendor": { "type": "string" },
        "document_version": { "type": "string" },
        "source_document": { "type": "string" }
      }
    },
    "global_requirements": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["part_id", "value", "quantity", "category"],
        "additionalProperties": false,
        "properties": {
          "part_id": { "type": "string", "minLength": 1 },
          "value": { "type": "string", "minLength": 1 },
          "quantity": { "type": "integer", "minimum": 1 },
          "category": {
            "type": "string",
            "enum": [
              "resistor",
              "capacitor",
              "potentiometer",
              "semiconductor",
              "ic",
              "socket",
              "switch",
              "jack",
              "hardware",
              "other"
            ]
          },
          "notes": { "type": "string" },
          "requirements": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          },
          "source_evidence": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "manufacturer_part_number": { "type": "string" },
          "mouser_part_number": { "type": "string" },
          "supplier": { "type": "string" },
          "product_url": { "type": "string" },
          "selection_rationale": { "type": "string" },
          "sourcing": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "query": { "type": "string" },
              "provider": { "type": "string" },
              "manufacturer_filters": {
                "type": "array",
                "items": { "type": "string" }
              },
              "search_strategy": { "type": "string" },
              "candidates": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "properties": {
                    "mouser_part_number": { "type": "string" },
                    "manufacturer_part_number": { "type": "string" },
                    "manufacturer": { "type": "string" },
                    "description": { "type": "string" },
                    "category": { "type": "string" },
                    "availability": { "type": "string" },
                    "in_stock_quantity": { "type": "integer" },
                    "orderable": { "type": "boolean" },
                    "lifecycle_status": { "type": "string" },
                    "lead_time": { "type": "string" },
                    "product_detail_url": { "type": "string" },
                    "datasheet_url": { "type": "string" },
                    "min": {},
                    "mult": {},
                    "price_breaks": { "type": "array" },
                    "score": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "sourcing": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string" },
        "note": { "type": "string" }
      }
    },
    "issues": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "required": ["severity", "message"],
        "additionalProperties": false,
        "properties": {
          "severity": { "type": "string", "enum": ["info", "warning", "error"] },
          "message": { "type": "string", "minLength": 1 },
          "affected_part_ids": {
            "type": "array",
            "items": { "type": "string" },
            "default": []
          }
        }
      }
    }
  }
}
